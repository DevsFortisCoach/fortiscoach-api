# Base de datos (Supabase Postgres) — una sola BD multi-tenant
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# JWT (mín. 32 caracteres; mismo valor que en el frontend)
JWT_SECRET=change-me-use-a-long-random-string

# Dominio base para subdominios de gimnasios
TENANT_BASE_DOMAIN=fortiscoach.cl

# En local, si accedes por localhost:3000 sin subdominio, define el slug del gym de prueba
DEV_TENANT_SLUG=primefitness

# CORS: origen por defecto si no coincide con *.fortiscoach.cl / localhost
CORS_DEFAULT_ORIGIN=https://fortiscoach.cl

# Permitir previews de Vercel (*.vercel.app) en staging
ALLOW_VERCEL_PREVIEW=true

# Hostnames extra permitidos (separados por coma), opcional
# CORS_EXTRA_HOSTS=

# SMTP / Brevo
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-smtp-login
SMTP_PASS=your-brevo-smtp-key
MAIL_FROM_EMAIL=no-reply@fortiscoach.cl
MAIL_FROM_NAME=FortisCoach
MAIL_REPLY_TO=support@fortiscoach.cl
SOCIO_APP_URL=https://primefitness.fortiscoach.cl/login/socio
