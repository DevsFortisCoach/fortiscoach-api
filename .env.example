# Mismo proyecto Supabase que fortiscoach-web (NEXT_PUBLIC_SUPABASE_URL).
# Recomendado: Connection string → Session pooler (host aws-0-….pooler.supabase.com)
# NO uses db.….supabase.co en local si ves ENETUNREACH (IPv6).
# La contraseña va SIN corchetes: postgres:TU_PASSWORD@host…
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres

JWT_SECRET=change-me-same-as-fortiscoach-web

FRONTEND_URL=https://app.fortiscoach.cl,http://localhost:3000

ALLOW_VERCEL_PREVIEW=true
